# UBotHub Environment Variables
# Copy this file to .env and fill in the values.

# ---- Database ----
POSTGRES_USER=ubothub
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=ubothub

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---- MinIO / Object Storage ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
STORAGE_PROVIDER=minio

# ---- Aliyun OSS (if STORAGE_PROVIDER=aliyun_oss) ----
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_CDN_DOMAIN=

# ---- JWT ----
JWT_SECRET=CHANGE_ME_MIN_256_BIT_RANDOM_STRING

# ---- Email (Alibaba DirectMail / SMTP) ----
SMTP_HOST=
SMTP_FROM_ADDRESS=
SMTP_PASSWORD=

# ---- Content Moderation ----
MODERATION_ACCESS_KEY_ID=
MODERATION_ACCESS_KEY_SECRET=
MODERATION_ENDPOINT=

# ---- WeChat Pay (Service Provider Mode) ----
WECHAT_SP_MCH_ID=
WECHAT_SP_APP_ID=
WECHAT_SUB_MCH_ID=
WECHAT_SUB_APP_ID=
WECHAT_SERIAL_NO=
WECHAT_API_V3_KEY=
WECHAT_PRIVATE_KEY=

# ---- Alipay (ISV Mode) ----
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
